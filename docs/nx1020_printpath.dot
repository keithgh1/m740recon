digraph nx1020_printpath {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc=t, label="Star NX-1020 firmware -- print path (line buffer -> print head)\nm740recon call-graph subset, device M50734"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=8];

  n_e4ac [label="sub_e4ac\nline / print dispatcher\n(per-mode column loops)", fillcolor="#cfe8ff"];
  n_e729 [label="sub_e729\nfetch next char\n(from line buffer)", fillcolor="#fff2cc"];
  n_f3fb [label="sub_f3fb\nglyph fetch\n(metrics + bitmap)", fillcolor="#ffe6b3"];
  n_f663 [label="sub_f663\nglyph-ROM bank select", fillcolor="#ffe6b3"];
  n_e804 [label="sub_e804\nemit columns\n(1 of ~20 per-mode)", fillcolor="#d9ead3"];
  n_e831 [label="sub_e831\nemit columns (variant)", fillcolor="#d9ead3"];
  n_f1d5 [label="sub_f1d5\ncolumn -> head-pin bit field", fillcolor="#b6d7a8"];
  n_f2c8 [label="sub_f2c8\ncolumn emit", fillcolor="#b6d7a8"];
  n_f394 [label="sub_f394\nHEAD FIRE / strobe\ngate-array reg0 [0x4000]\nP0.4 STBOUT, STBT", fillcolor="#f4a3a3"];
  n_ff9f [label="sub_ff9f\nadvance column ptr", fillcolor="#e0e0e0"];

  n_e4ac -> n_e729 [style=solid];
  n_e4ac -> n_e804 [style=solid];
  n_e4ac -> n_e831 [style=solid];
  n_e4ac -> n_f3fb [style=solid];
  n_e4ac -> n_ff9f [style=solid];
  n_e804 -> n_f1d5 [style=solid];
  n_e831 -> n_f1d5 [style=solid];
  n_f1d5 -> n_f2c8 [style=dashed, label=tail];
  n_f2c8 -> n_f394 [style=dashed, label=tail];
  n_f3fb -> n_f663 [style=solid];

  isr [shape=note, style=filled, fillcolor="#f5f5f5", fontsize=9, label="carriage / paper stepping is\ninterrupt-driven (Timer1/2/3 + HE/VE ISRs)\n(not reachable via call edges)"];
  n_f394 -> isr [style=dotted, dir=none, constraint=false];
}
